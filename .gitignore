visionai_env.tar.gz
*.tar.gz

# Model AI (nặng)
models/yolo/*.pt
models/yolo/*.pth
models/cnn/*.h5
models/cnn/*.pkl
models/*.pth

# Frontend
node_modules/
frontend/node_modules/
.next/
out/
build/
dist/
frontend/build/
frontend/dist/

# Backend Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.eggs/
.venv/
venv/
ENV/

# File cấu hình cá nhân (chứa mật khẩu)
.env
.env.local
.env.production
.env.development
secrets.py
config_local.py

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# Hệ điều hành
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# File tạm
*.tmp
*.temp
temp/
tmp/
*.cache


# File thuyết minh (tránh conflict)
*.docx
~$*.docx